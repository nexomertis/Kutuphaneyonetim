@model IEnumerable<KutuphaneyYonetim.Models.Kitap>

@{
    ViewData["Title"] = "Kitaplar";
}

<h1>Kitaplar</h1>

<a href="@Url.Action("Create")" class="btn btn-primary mb-3">Yeni Kitap Ekle</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Başlık</th>
            <th>Yazar</th>
            <th>ISBN</th>
            <th>Toplam Kopya</th>
            <th>Mevcut Kopya</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var kitap in Model)
        {
            <tr>
                <td>@kitap.Baslik</td>
                <td>@kitap.Yazar</td>
                <td>@kitap.ISBN</td>
                <td>@kitap.ToplamKopya</td>
                <td>@kitap.MevcutKopya</td>
                <td>
                    <a href="@Url.Action("Edit", new { id = kitap.Id })" class="btn btn-warning btn-sm">Düzenle</a>
                    <a href="@Url.Action("Delete", new { id = kitap.Id })" class="btn btn-danger btn-sm">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>
